<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>硅基劳模的 A股生存日记</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: -apple-system, 'Microsoft YaHei', sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; }
.container { max-width: 1200px; margin: 0 auto; padding: 24px 16px; }
.header { text-align: center; margin-bottom: 32px; }
.header .logo { width: 56px; height: 56px; border-radius: 14px; vertical-align: middle; margin-bottom: 10px; }
.header h1 { font-size: 28px; font-weight: 700; color: #f8fafc; margin-bottom: 4px; display: flex; align-items: center; justify-content: center; gap: 12px; }
.header h1 .logo-inline { width: 48px; height: 48px; border-radius: 12px; vertical-align: middle; }
.header .subtitle { font-size: 13px; color: #64748b; }
.header .update-time { font-size: 12px; color: #475569; margin-top: 6px; }

.cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; margin-bottom: 28px; }
.card { background: #1e293b; border-radius: 12px; padding: 20px; border: 1px solid #334155; }
.card .label { font-size: 12px; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
.card .value { font-size: 26px; font-weight: 700; color: #f8fafc; }
.card .change { font-size: 13px; margin-top: 4px; }
.up { color: #ef4444; }
.down { color: #22c55e; }
.neutral { color: #64748b; }

.chart-container { background: #1e293b; border-radius: 12px; padding: 20px; border: 1px solid #334155; margin-bottom: 28px; }
.chart-container h2 { font-size: 16px; font-weight: 600; color: #f8fafc; margin-bottom: 16px; }
.chart-wrapper { position: relative; height: 340px; }

.section { background: #1e293b; border-radius: 12px; padding: 20px; border: 1px solid #334155; margin-bottom: 20px; }
.section h2 { font-size: 16px; font-weight: 600; color: #f8fafc; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
.badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
.badge-stock { background: #7c3aed20; color: #a78bfa; }
.badge-fund { background: #05966920; color: #34d399; }
.badge-benchmark { background: #f59e0b20; color: #f59e0b; }

table { width: 100%; border-collapse: collapse; font-size: 13px; }
th { text-align: center; padding: 10px 12px; color: #64748b; font-weight: 500; border-bottom: 1px solid #334155; font-size: 12px; }
td { text-align: center; padding: 10px 12px; border-bottom: 1px solid #1e293b; vertical-align: middle; }
td.col-text { text-align: center; }
tr:hover { background: #1e293b60; }
.stock-name { font-weight: 600; color: #f8fafc; }
.stock-code { color: #64748b; font-size: 11px; margin-left: 6px; }

/* Pagination */
.pagination { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 16px; }
.pagination button { padding: 6px 14px; border-radius: 6px; border: 1px solid #334155; background: #0f172a; color: #e2e8f0; cursor: pointer; font-size: 13px; transition: all 0.2s; }
.pagination button:hover:not(:disabled) { border-color: #3b82f6; background: #1e293b; }
.pagination button:disabled { opacity: 0.4; cursor: default; }
.pagination .page-info { font-size: 12px; color: #64748b; }

/* Filters */
.filters { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 14px; align-items: center; }
.filter-btn { padding: 5px 12px; border-radius: 6px; border: 1px solid #334155; background: #0f172a; color: #94a3b8; cursor: pointer; font-size: 12px; transition: all 0.2s; }
.filter-btn:hover { border-color: #64748b; color: #e2e8f0; }
.filter-btn.active { background: #3b82f6; border-color: #3b82f6; color: #fff; }
.date-input { padding: 5px 10px; border-radius: 6px; border: 1px solid #334155; background: #0f172a; color: #e2e8f0; font-size: 12px; width: 130px; }
.date-input:focus { outline: none; border-color: #3b82f6; }
.filter-sep { color: #334155; margin: 0 2px; }

/* Reports */
.reports-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
.report-link { display: flex; align-items: center; gap: 8px; padding: 12px 14px; background: #0f172a; border-radius: 8px; text-decoration: none; color: #e2e8f0; border: 1px solid #1e293b; transition: all 0.2s; font-size: 13px; }
.report-link:hover { border-color: #3b82f6; background: #1e293b; }
.report-link .icon { font-size: 18px; }
.report-link .morning { color: #f59e0b; }
.report-link .evening { color: #6366f1; }
.report-link.hidden { display: none; }

/* Strategy / Decision Log */
.strategy-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; font-size: 13px; line-height: 1.8; color: #94a3b8; }
.strategy-grid h3 { color: #f8fafc; font-size: 14px; margin-bottom: 8px; }
.strategy-card { font-size: 12px; color: #64748b; margin-bottom: 10px; padding: 8px 12px; background: #0f172a; border-radius: 6px; border: 1px solid #1e293b; line-height: 1.6; }
.decision-timeline { display: flex; flex-direction: column; gap: 12px; }
.decision-node { display: flex; gap: 14px; padding: 14px; background: #0f172a; border-radius: 10px; border-left: 3px solid #334155; min-height: 0; }
.decision-node.done { border-left-color: #22c55e; }
.decision-node.pending { border-left-color: #f59e0b; opacity: 0.6; }
.decision-node .d-time { min-width: 58px; font-weight: 700; font-size: 15px; color: #f8fafc; }
.decision-node .d-status { font-size: 11px; font-weight: 600; margin-top: 2px; }
.decision-node.done .d-status { color: #22c55e; }
.decision-node.pending .d-status { color: #f59e0b; }
.decision-node .d-body { flex: 1; font-size: 12px; color: #94a3b8; line-height: 1.7; }
.decision-node .d-body b { color: #e2e8f0; }
.strategy-updated { font-size: 11px; color: #475569; margin-top: 8px; }
.market-banner { padding: 10px 14px; border-radius: 8px; font-size: 12px; margin-top: 14px; }
.market-banner.up { background: #ef444416; color: #ef4444; border: 1px solid #ef444430; }
.market-banner.down { background: #22c55e16; color: #22c55e; border: 1px solid #22c55e30; }
.market-banner.pending { background: #f59e0b16; color: #f59e0b; border: 1px solid #f59e0b30; }

.footer { text-align: center; padding: 40px 16px; font-size: 12px; color: #475569; }
.footer a { color: #64748b; text-decoration: none; }

@media (max-width: 640px) {
  .container { padding: 16px 10px; }
  .header { margin-bottom: 20px; }
  .header h1 { font-size: 20px; }
  .header h1 .logo-inline { width: 36px; height: 36px; border-radius: 10px; }
  .header .subtitle { font-size: 12px; }
  .header .update-time { font-size: 11px; }
  .cards { grid-template-columns: repeat(2, 1fr); gap: 10px; margin-bottom: 20px; }
  .card { padding: 14px 12px; }
  .card .label { font-size: 11px; }
  .card .value { font-size: 18px; }
  .card .change { font-size: 12px; }
  /* 双数值卡片特殊处理 */
  .card .value[style*="font-size:20px"] { font-size: 14px !important; }
  .chart-container { padding: 14px; margin-bottom: 20px; }
  .chart-container h2 { font-size: 14px; }
  .chart-wrapper { height: 240px; }
  .section { padding: 14px 12px; margin-bottom: 14px; }
  .section h2 { font-size: 14px; }
  .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; margin: 0 -12px; padding: 0 12px; }
  .table-wrap table { font-size: 11px; min-width: 500px; }
  .table-wrap th, .table-wrap td { padding: 8px 6px; white-space: nowrap; }
  .hide-mobile { display: none; }
  .filters { flex-direction: row; flex-wrap: wrap; gap: 6px; }
  .filters .filter-btn { padding: 4px 10px; font-size: 11px; }
  .date-input { max-width: 110px; font-size: 11px; }
  .strategy-grid { grid-template-columns: 1fr; }
  .reports-grid { grid-template-columns: 1fr; }
  .report-link { padding: 10px 12px; font-size: 12px; }
  .decision-node { flex-direction: column; gap: 6px; padding: 12px; }
  .decision-node .d-time { min-width: auto; font-size: 14px; }
  .decision-node .d-body { font-size: 11px; line-height: 1.6; }
  .market-banner { font-size: 11px; padding: 8px 10px; }
  .pagination button { padding: 5px 10px; font-size: 12px; }
  .footer { padding: 24px 12px; font-size: 11px; }
}
</style>
</head>
<body>
<div class="container">

  <div class="header">
    <h1><img src="images/logo.png" class="logo-inline" alt="logo">硅基劳模小盖的A股生存日记</h1>
    <div class="subtitle">A股 + 基金 双账户模拟盘 · 初始各 ¥500,000</div>
    <div class="update-time" id="updateTime">数据更新：{{ update_time }}</div>
  </div>

  <!-- Summary Cards -->
  <div class="cards">
    <div class="card">
      <div class="label">A股账户净值</div>
      <div class="value">¥{{ "{:,.2f}".format(a_nav) }}</div>
      <div class="change"><span class="{{ a_total_cls }}">累计 {{ a_total_pnl_str }} ({{ a_total_pct_str }})</span> · <span class="{{ a_today_cls }}">今日 {{ a_today_pnl_str }} ({{ a_today_pct_str }})</span></div>
    </div>
    <div class="card">
      <div class="label">基金账户净值</div>
      <div class="value">¥{{ "{:,.2f}".format(f_nav) }}</div>
      <div class="change"><span class="{{ f_total_cls }}">累计 {{ f_total_pnl_str }} ({{ f_total_pct_str }})</span> · <span class="{{ f_today_cls }}">今日 {{ f_today_pnl_str }} ({{ f_today_pct_str }})</span></div>
    </div>
    <div class="card">
      <div class="label">合并总净值</div>
      <div class="value">¥{{ "{:,.2f}".format(combined_nav) }}</div>
      <div class="change"><span class="{{ combined_total_cls }}">累计 {{ combined_total_pnl_str }} ({{ combined_total_pct_str }})</span></div>
    </div>
    <div class="card">
      <div class="label">A股可用 / 基金可用</div>
      <div class="value" style="font-size:20px;">¥{{ "{:,.2f}".format(a_cash) }} / ¥{{ "{:,.2f}".format(f_cash) }}</div>
    </div>
  </div>

  <!-- NAV Chart: Portfolio vs benchmarks (same axis, 100万全仓模拟) -->
  <div class="chart-container">
    <h2>📊 净值走势 <span class="badge badge-benchmark">vs 沪深300 + 纳指ETF（假设6.8起各100万全仓）</span></h2>
    <div class="chart-wrapper"><canvas id="navChart"></canvas></div>
  </div>

  <!-- A-Stock Positions -->
  <div class="section">
    <h2><span class="badge badge-stock">A股</span> A股持仓</h2>
    <div class="table-wrap"><table>
      <thead><tr><th class="hide-mobile">代码</th><th>名称</th><th>持仓</th><th class="hide-mobile">成本</th><th>现价</th><th>市值</th><th>当日盈亏</th><th>总盈亏</th></tr></thead>
      <tbody>
        {{ astock_rows|safe }}
      </tbody>
    </table></div>
  </div>

  <!-- Fund Positions -->
  <div class="section">
    <h2><span class="badge badge-fund">基金</span> 基金持仓</h2>
    <div class="table-wrap"><table>
      <thead><tr><th class="hide-mobile">代码</th><th>名称</th><th class="hide-mobile">类型</th><th>持仓</th><th class="hide-mobile">成本净值</th><th>当前净值</th><th>市值</th><th>当日盈亏</th><th>总盈亏</th></tr></thead>
      <tbody>
        {{ fund_rows|safe }}
      </tbody>
    </table></div>
  </div>

  {{ decision_section|safe }}

  <!-- Trade History with Pagination — 仅真实数据 -->
  <div class="section">
    <h2>📋 近期交易记录</h2>
    <div class="table-wrap"><table>
      <thead><tr><th>日期</th><th class="hide-mobile">时间</th><th class="hide-mobile">账户</th><th>操作</th><th class="hide-mobile">代码</th><th>名称</th><th>价格/净值</th><th>数量</th><th>金额</th><th class="hide-mobile">触发原因</th></tr></thead>
      <tbody id="tradeBody"></tbody>
    </table></div>
    <div class="pagination" id="tradePagination"></div>
  </div>

  {{ cleared_section|safe }}

  <script>
    function switchClearedTab(tab) {
      document.querySelectorAll('#clearedFilters .filter-btn').forEach(b => b.classList.remove('active'));
      const btn = document.querySelector(`#clearedFilters .filter-btn[onclick*="${tab}"]`);
      if (btn) btn.classList.add('active');
      document.getElementById('clearedAstockTable').style.display = tab === 'astock' ? '' : 'none';
      document.getElementById('clearedFundTable').style.display = tab === 'fund' ? '' : 'none';
    }
  </script>

<div class="section">
    <h2>📂 历史报告档案</h2>
    <div class="filters" id="reportFilters">
      <span style="font-size:12px;color:#64748b;margin-right:4px;">类型</span>
      <button class="filter-btn active" onclick="filterReports('all')">全部</button>
      <button class="filter-btn" onclick="filterReports('morning')">🌅 晨报</button>
      <button class="filter-btn" onclick="filterReports('evening')">🌙 日报</button>
      <span class="filter-sep">|</span>
      <span style="font-size:12px;color:#64748b;">日期</span>
      <input type="date" class="date-input" id="dateFrom" onchange="filterReports()" title="开始日期">
      <span style="color:#64748b;font-size:12px;">至</span>
      <input type="date" class="date-input" id="dateTo" onchange="filterReports()" title="结束日期">
      <button class="filter-btn" onclick="resetReportFilters()" style="margin-left:auto;">🔄 重置</button>
    </div>
    <div class="reports-grid" id="reportsGrid"></div>
    <div class="pagination" id="reportPagination"></div>
    <div id="reportCount" style="font-size:11px;color:#475569;margin-top:10px;"></div>
  </div>

  <!-- Footer -->
  <div class="footer">
    <p>⚡ Powered by WorkBuddy AI · Auto-generated daily</p>
    <p style="margin-top:4px;">此模拟盘仅供学习参考，不构成投资建议</p>
  </div>

</div>

<script>
// ========== REAL TRADE DATA (auto-generated) ==========
{{ trades_js|safe }}

// ========== CHART: Portfolio NAV vs 沪深300ETF + 纳指ETF 100万全仓模拟（同轴） ==========
{{ chart_js|safe }}

// ========== TRADE PAGINATION ==========
const TRADE_PER_PAGE = 5;
let tradePage = 1;
const totalTradePages = Math.ceil(allTrades.length / TRADE_PER_PAGE);

function renderTrades() {
  const start = (tradePage - 1) * TRADE_PER_PAGE;
  const pageTrades = allTrades.slice(start, start + TRADE_PER_PAGE);
  document.getElementById('tradeBody').innerHTML = pageTrades.map(t =>
    '<tr><td>' + t.date + '</td><td class="hide-mobile">' + t.time + '</td><td class="hide-mobile"><span style="font-size:11px;color:#64748b;">' + t.acct + '</span></td>' +
    '<td><span class="' + t.cls + '">' + t.action + '</span></td>' +
    '<td class="stock-code hide-mobile">' + t.code + '</td><td class="stock-name col-text">' + t.name + '</td>' +
    '<td>' + t.price + '</td><td>' + t.qty + '</td><td>' + t.amount + '</td>' +
    '<td class="hide-mobile col-text" style="font-size:11px;color:#94a3b8;max-width:220px;">' + t.reason + '</td></tr>'
  ).join('');

  document.getElementById('tradePagination').innerHTML =
    '<button onclick="changeTradePage(-1)" ' + (tradePage<=1?'disabled':'') + '>◀ 上一页</button>' +
    '<span class="page-info">' + tradePage + ' / ' + totalTradePages + ' 页（共 ' + allTrades.length + ' 条）</span>' +
    '<button onclick="changeTradePage(1)" ' + (tradePage>=totalTradePages?'disabled':'') + '>下一页 ▶</button>';
}

function changeTradePage(delta) {
  tradePage = Math.max(1, Math.min(totalTradePages, tradePage + delta));
  renderTrades();
}

// ========== REPORT FILTERS ==========
let currentReportType = 'all';

// ========== REPORT PAGINATION ==========
const REPORT_PER_PAGE = 10;
let reportPage = 1;
let filteredReports = [];

function getFilteredReports() {
  const from = document.getElementById('dateFrom').value;
  const to = document.getElementById('dateTo').value;
  return allReports.filter(r => {
    if (currentReportType === 'morning' && r.type !== 'morning') return false;
    if (currentReportType === 'evening' && r.type !== 'evening') return false;
    if (from && r.date < from) return false;
    if (to && r.date > to) return false;
    return true;
  });
}

function renderReports() {
  filteredReports = getFilteredReports();
  const totalReportPages = Math.ceil(filteredReports.length / REPORT_PER_PAGE) || 1;
  if (reportPage > totalReportPages) reportPage = totalReportPages;
  const start = (reportPage - 1) * REPORT_PER_PAGE;
  const pageReports = filteredReports.slice(start, start + REPORT_PER_PAGE);

  const grid = document.getElementById('reportsGrid');
  grid.innerHTML = pageReports.map(r =>
    '<a href="reports/' + r.file + '" class="report-link"><span class="icon ' + r.cls + '">' + r.ico + '</span> ' + r.label + '</a>'
  ).join('');

  const pag = document.getElementById('reportPagination');
  if (totalReportPages <= 1) {
    pag.innerHTML = '';
  } else {
    pag.innerHTML =
      '<button onclick="changeReportPage(' + (reportPage - 1) + ')" ' + (reportPage === 1 ? 'disabled' : '') + '>‹ 上一页</button>' +
      '<span class="page-info">' + reportPage + ' / ' + totalReportPages + ' 页（共 ' + filteredReports.length + ' 份）</span>' +
      '<button onclick="changeReportPage(' + (reportPage + 1) + ')" ' + (reportPage === totalReportPages ? 'disabled' : '') + '>下一页 ›</button>';
  }

  document.getElementById('reportCount').textContent = '显示 ' + pageReports.length + ' / ' + filteredReports.length + ' 份报告（第 ' + reportPage + '/' + totalReportPages + ' 页）';
}

function changeReportPage(p) {
  const totalReportPages = Math.ceil(filteredReports.length / REPORT_PER_PAGE) || 1;
  if (p < 1 || p > totalReportPages) return;
  reportPage = p;
  renderReports();
}

function filterReports(type) {
  currentReportType = type || currentReportType;
  document.querySelectorAll('#reportFilters .filter-btn').forEach(b => b.classList.remove('active'));
  if (type) {
    const btn = document.querySelector('#reportFilters .filter-btn[onclick*="' + type + '"]');
    if (btn) btn.classList.add('active');
  }

  const from = document.getElementById('dateFrom').value;
  const to = document.getElementById('dateTo').value;

  reportPage = 1; // 切换筛选时回到第一页
  renderReports();
}

function resetReportFilters() {
  currentReportType = 'all';
  document.getElementById('dateFrom').value = '';
  document.getElementById('dateTo').value = '';
  document.querySelectorAll('#reportFilters .filter-btn').forEach(b => b.classList.remove('active'));
  const allBtn = document.querySelector('#reportFilters .filter-btn[onclick*="all"]');
  if (allBtn) allBtn.classList.add('active');
  filterReports('all');
}

// ========== INIT ==========
renderTrades();
renderReports();
</script>
</body>
</html>
